# Non-secret example env. Real secrets live in AWS Secrets Manager (P3-D section 7).
NODE_ENV=development
API_PORT=3000
DEPLOYMENT_ENVIRONMENT=development
ASSET_BUCKET_NAME=traverse-local-assets
COACH_APP_BASE_URL=http://localhost:5173
CLIENT_APP_BASE_URL=http://localhost:5174
AUTH_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
CLIENT_EMAIL_FROM="Traverse <no-reply@example.test>"

# Decision V15 defaults. Override locally only when testing another valid configuration.
TRAVERSE_VIDEO_MAX_SECONDS_COACH=180
TRAVERSE_VIDEO_MAX_SECONDS_CLIENT=90
TRAVERSE_VIDEO_UNDO_WINDOW_SECONDS=10
